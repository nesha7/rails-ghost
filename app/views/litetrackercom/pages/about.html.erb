<% content_for :title, "#{resolve_title_metadata(request.path)}" %>

<main>
  <section id="about-hero-section" class="bg-[#F6F6F8] relative px-6 pt-14 sm:pt-24 lg:px-8 flex flex-col justify-start gap-y-24 opacity-0 animate-fade-in">
    <div class="mx-auto max-w-4xl pt-16 sm:pt-24">
      <div class="mx-auto max-w-2xl flex flex-col gap-y-6 justify-center w-full text-center">
        <div class="flex items-center justify-center text-green-dark text-xs">
          <svg class="h-4 w-4"  fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <p class="pl-1 font-bold">About us</p>
        </div>
        <h3 class="text-heading sm:text-6xl tracking-wide">
          <%#= phrase('litetracker_about-hero-header') %>
          Software Agency building products
        </h3>
        <p class="text-base font-normal text-gray-500 sm:text-lg/8">
          <%#= phrase('litetracker_about-hero-subheader') %>
          Founded in 2011 we built products for mostly US based startups and Enterprises. ISO 27001 certified and aiming for long serving products.
        </p>
      </div>
    </div>
    <div class="max-w-7xl min-w-auto mx-auto flex justify-center pb-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 justify-center gap-8">
        <div class="flex flex-col items-center justify-center gap-8 w-full h-145">
          <%= image_tag 'litetracker/about-1.avif', width: "2048", height: "1367", class: "w-full h-full rounded-2xl bg-white/5 shadow-2xl ring-1 ring-white/10 object-cover object-center" %>
        </div>
        <div class="flex flex-col items-center justify-center gap-8 w-full h-145">
          <div class="w-full h-68.5">
            <%= image_tag 'litetracker/about-2.avif', width: "1360", height: "908", class: "w-full h-full rounded-2xl bg-white/5 shadow-2xl ring-1 ring-white/10 object-cover object-center" %>
          </div>
          <div class="w-full h-68.5">
            <%= image_tag 'litetracker/about-3.avif', width: "1360", height: "908", class: "w-full h-full rounded-2xl bg-white/5 shadow-2xl ring-1 ring-white/10 object-cover object-center" %>
          </div>
        </div>
      </div>
    </div>
  </section>

