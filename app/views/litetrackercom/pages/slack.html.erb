              <path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.527 2.527 0 0 1-2.521-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/>
              <path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.521-2.522v-2.522h2.521zm0-1.27a2.527 2.527 0 0 1-2.521-2.522 2.527 2.527 0 0 1 2.521-2.521h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/>
            </svg>
            Add to Slack
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="relative px-6 py-16 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-heading sm:text-4xl">How it works</h2>
        <p class="mt-4 text-base font-normal text-gray-500 sm:text-lg/8">Get set up in minutes with just a few simple steps.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
        <div class="flex flex-col items-center text-center gap-4">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[#F6F6F8] text-black-light font-bold text-lg">1</div>
          <h3 class="text-lg font-semibold text-black-light">Add to Slack</h3>
          <p class="text-sm text-gray-500">Click the "Add to Slack" button above and authorize LiteTracker to access your Slack workspace.</p>
        </div>
        <div class="flex flex-col items-center text-center gap-4">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[#F6F6F8] text-black-light font-bold text-lg">2</div>
          <h3 class="text-lg font-semibold text-black-light">Pick a channel</h3>
          <p class="text-sm text-gray-500">Choose which Slack channel should receive LiteTracker notifications for your project.</p>
        </div>
        <div class="flex flex-col items-center text-center gap-4">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[#F6F6F8] text-black-light font-bold text-lg">3</div>
          <h3 class="text-lg font-semibold text-black-light">Stay in the loop</h3>
          <p class="text-sm text-gray-500">Get real-time updates on story changes, comments, and project activity right in Slack.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="bg-[#F6F6F8] relative px-6 py-16 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-heading sm:text-4xl">What you get</h2>
        <p class="mt-4 text-base font-normal text-gray-500 sm:text-lg/8">Stay on top of your projects without switching tools.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-green-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            <h3 class="text-lg font-semibold text-black-light">Real-time notifications</h3>
          </div>
          <p class="text-sm text-gray-500">Get notified instantly when stories are created, updated, started, finished, or delivered.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-green-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
            </svg>
            <h3 class="text-lg font-semibold text-black-light">Comment updates</h3>
          </div>
          <p class="text-sm text-gray-500">See new comments and discussions on stories as they happen, keeping everyone in the conversation.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-green-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <h3 class="text-lg font-semibold text-black-light">Team visibility</h3>
          </div>
          <p class="text-sm text-gray-500">Your whole team stays informed about project progress without needing to check LiteTracker constantly.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-green-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            <h3 class="text-lg font-semibold text-black-light">Quick setup</h3>
          </div>
          <p class="text-sm text-gray-500">Connect your workspace in seconds. No complex configuration or technical knowledge required.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative px-6 py-16 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-heading sm:text-4xl">Ready to connect?</h2>
      <p class="mt-4 text-base font-normal text-gray-500 sm:text-lg/8">
        Add LiteTracker to your Slack workspace and never miss an important project update again.
      </p>
      <div class="flex justify-center pt-8">
        <a href="https://slack.com/apps/A08A0DBV5C2" target="_blank" rel="noopener noreferrer" data-umami-event="slack-add-click-bottom" class="inline-flex items-center gap-3 rounded-lg bg-white border border-gray-200 shadow-lg px-6 py-3 text-base font-semibold text-gray-900 hover:shadow-xl hover:border-gray-300 transition-all duration-200">
