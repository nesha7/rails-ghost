<% content_for :title, "Add to Slack | LiteTracker" %>
<% content_for :description, "Add LiteTracker to your Slack workspace to receive real-time notifications about story updates, comments, and project activity directly in your Slack channels." %>

<main>
  <!-- Hero Section -->
  <section class="bg-[#F6F6F8] relative px-6 pt-14 sm:pt-24 lg:px-8 flex flex-col justify-start shadow-[inset_0_-2px_4px_-3px_#0003]">
    <div class="mx-auto max-w-4xl pt-16 sm:pt-24 pb-16 sm:pb-24">
      <div class="mx-auto max-w-2xl flex flex-col gap-y-6 justify-center w-full text-center">
        <div class="flex items-center justify-center gap-1 text-xs">
          <div class="aspect-square w-5">
            <%= image_tag 'litetracker/integrations-slack.png', class: "w-full h-full object-cover", alt: 'Slack' %>
          </div>
          <p class="pl-1 font-bold text-black-light">Slack Integration</p>
        </div>
        <h1 class="text-heading sm:text-6xl tracking-wide">
          Add LiteTracker to Slack
        </h1>
        <p class="text-base font-normal text-gray-500 sm:text-lg/8">
          Get instant notifications about story updates, comments, and project activity delivered directly to your Slack channels. Keep your team in the loop without leaving Slack.
        </p>
        <div class="flex justify-center pt-4">
          <a href="https://slack.com/apps/A08A0DBV5C2" target="_blank" rel="noopener noreferrer" data-umami-event="slack-add-click" class="inline-flex items-center gap-3 rounded-lg bg-white border border-gray-200 shadow-lg px-6 py-3 text-base font-semibold text-gray-900 hover:shadow-xl hover:border-gray-300 transition-all duration-200">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/>
